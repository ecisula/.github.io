# Файл .env — заповни свої ключі та видали цей рядок перед збереженням

# ─── OpenAI API (рекомендовано для початку) ───────────────────────────────
# Отримай ключ на https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-замінити_на_свій_ключ

# Модель: gpt-4o-mini дешева, gpt-4o — найрозумніша
OPENAI_MODEL_NAME=gpt-4o-mini

# ─── Ollama (локальна модель без оплати) ──────────────────────────────────
# Встанови Ollama: https://ollama.com
# Потім запусти: ollama pull llama3
# Розкоментуй рядки нижче та ЗАКОМЕНТУЙ OPENAI_API_KEY вище

# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL_NAME=ollama/llama3
